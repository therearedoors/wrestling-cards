<%- include('../../include/header') %>
<link rel="stylesheet" href="/css/games/rawdeal.css">

<div class="rd-page" data-rd-dev="<%= devMode ? '1' : '0' %>">
    <section id="rd-setup" class="rd-setup">
        <div class="rd-setup-card">
            <h2>Choose Your Superstar</h2>
            <label for="rd-deck-select">Starter Deck</label>
            <select id="rd-deck-select" class="rd-select">
                <option value="rock">The Rock</option>
                <option value="austin">"Stone Cold" Steve Austin</option>
                <option value="undertaker">The Undertaker</option>
                <option value="mankind">Mankind</option>
                <option value="hhh">Triple H</option>
                <option value="kane">Kane</option>
                <option value="jericho">Chris Jericho</option>
            </select>
            <p class="rd-setup-note">
                You'll face the rival starter deck. The opponent won't play cards — overturn reversals from their Arsenal still work.
            </p>
            <p id="rd-override-note" class="rd-setup-note rd-setup-note--override hidden">
                Using your saved deck customizations from the <a href="/decks">Deck Builder</a>.
            </p>
            <p class="rd-setup-links">
                <a href="/decks">Edit Decks</a>
                <% if (!devMode) { %>
                    · <a href="/practice?dev=1">Dev Mode</a>
                <% } %>
            </p>
            <button id="rd-start-btn" class="rd-btn rd-btn--primary">Start Match</button>
        </div>
    </section>

    <section id="rd-game" class="rd-game hidden">
        <div class="rd-play-layout">
            <div id="rd-board" class="rd-board">
                <div class="rd-status-bar">
                    <span id="rd-phase" class="rd-phase">Main Step</span>
                    <span id="rd-turn" class="rd-turn">Turn 1</span>
                    <button id="rd-superstar-ability" class="rd-btn rd-btn--ability hidden" type="button" title="">Superstar Ability</button>
                    <div id="rd-log" class="rd-log"></div>
                    <button id="rd-end-turn" class="rd-btn rd-btn--secondary">End Turn</button>
                </div>

                <div id="rd-ability-prompt" class="rd-ability-prompt hidden" aria-live="polite">
                    <span id="rd-ability-prompt-text"></span>
                </div>

                <div id="rd-reversal-banner" class="rd-reversal-banner hidden" aria-live="polite">
                    <span class="rd-reversal-banner__icon">✕</span>
                    <span id="rd-reversal-banner-text"></span>
                </div>

                <div class="rd-playfield">
                    <div class="rd-opponent-zone">
                        <div class="rd-superstar-bar rd-superstar-bar--opponent">
                            <span id="rd-opponent-superstar">Opponent</span>
                            <span class="rd-arsenal-label">Arsenal: <strong id="rd-opponent-arsenal-count">0</strong> · Hand: <strong id="rd-opponent-hand-count">0</strong></span>
                        </div>
                        <div class="rd-piles">
                            <div class="rd-superstar-slot" id="rd-opponent-superstar-card" title="Opponent Superstar"></div>
                            <div class="rd-pile" id="rd-opponent-arsenal" title="Opponent Arsenal">
                                <span class="rd-pile__label">Arsenal</span>
                                <div class="rd-pile__stack"></div>
                            </div>
                            <div class="rd-pile rd-pile--inspect" id="rd-opponent-ringside" data-rd-pile-type="ringside" data-rd-pile-seat="1" title="Click empty space to view all cards">
                                <span class="rd-pile__label" data-rd-pile-label>Ringside</span>
                                <div class="rd-pile__cards" id="rd-opponent-ringside-cards"></div>
                                <div class="rd-pile__hit" data-rd-pile-hit aria-hidden="true"></div>
                            </div>
                            <div class="rd-pile rd-pile--inspect" id="rd-opponent-ring" data-rd-pile-type="ring" data-rd-pile-seat="1" title="Click empty space to view all cards">
                                <span class="rd-pile__label" data-rd-pile-label>Ring</span>
                                <div class="rd-pile__cards" id="rd-opponent-ring-cards"></div>
                                <div class="rd-pile__hit" data-rd-pile-hit aria-hidden="true"></div>
                            </div>
                        </div>
                    </div>

                    <div class="rd-ring-zone rd-ring-zone--inspect" data-rd-pile-type="ring" data-rd-pile-seat="0" title="Click empty space to view all cards">
                        <div class="rd-ring-header">
                            <span class="rd-zone-title" id="rd-player-ring-title" data-rd-ring-title>Your Ring</span>
                            <div class="rd-player-stats">
                                <span id="rd-player-superstar" class="rd-player-name">You</span>
                                <span class="rd-fortitude">Fortitude: <strong id="rd-player-fortitude">0</strong></span>
                                <span class="rd-arsenal-label">Arsenal: <strong id="rd-player-arsenal-count">0</strong> · Hand: <strong id="rd-player-hand-count">0</strong></span>
                            </div>
                        </div>
                        <div class="rd-ring-compact" id="rd-player-ring-compact">
                            <div class="rd-ring-compact__cards" id="rd-player-ring-cards"></div>
                        </div>
                        <div class="rd-piles rd-piles--player">
                            <div class="rd-superstar-slot" id="rd-player-superstar-card" title="Your Superstar"></div>
                            <div class="rd-pile rd-pile--compact" id="rd-player-arsenal" title="Your Arsenal">
                                <span class="rd-pile__label">Your Arsenal</span>
                                <div class="rd-pile__stack"></div>
                            </div>
                            <div class="rd-pile rd-pile--compact rd-pile--inspect" id="rd-player-ringside" data-rd-pile-type="ringside" data-rd-pile-seat="0" title="Click empty space to view all cards">
                                <span class="rd-pile__label" data-rd-pile-label>Your Ringside</span>
                                <div class="rd-pile__cards" id="rd-player-ringside-cards"></div>
                                <div class="rd-pile__hit" data-rd-pile-hit aria-hidden="true"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rd-hand-zone">
                    <span class="rd-zone-title">Your Hand</span>
                    <div class="rd-hand-scroll" id="rd-hand-scroll">
                        <div id="rd-player-hand" class="rd-hand"></div>
                    </div>
                </div>

                <div id="rd-choice-modal" class="rd-choice-modal hidden" role="dialog" aria-modal="true" aria-labelledby="rd-choice-modal-message">
                    <div class="rd-choice-modal__backdrop"></div>
                    <div class="rd-choice-modal__panel">
                        <p id="rd-choice-modal-message" class="rd-choice-modal__message" data-rd-choice-message></p>
                        <div class="rd-choice-modal__actions" data-rd-choice-actions></div>
                    </div>
                </div>

                <div id="rd-pile-view-modal" class="rd-pile-view-modal hidden" role="dialog" aria-modal="true">
                    <div class="rd-pile-view-modal__backdrop" aria-hidden="true"></div>
                    <div class="rd-pile-view-modal__panel">
                        <p class="rd-pile-view-modal__title" data-rd-pile-view-title></p>
                        <div class="rd-pile-view-modal__body" data-rd-pile-view-body></div>
                        <button type="button" class="rd-btn rd-btn--primary" data-rd-pile-view-done>Done</button>
                    </div>
                </div>

                <div id="rd-superstar-ability-modal" class="rd-superstar-ability-modal hidden" role="dialog" aria-modal="true">
                    <div class="rd-superstar-ability-modal__backdrop" aria-hidden="true"></div>
                    <div class="rd-superstar-ability-modal__panel">
                        <p class="rd-superstar-ability-modal__message" data-rd-superstar-ability-message></p>
                        <div class="rd-superstar-ability-modal__scroll" data-rd-superstar-ability-cards></div>
                        <div class="rd-superstar-ability-modal__actions">
                            <button type="button" class="rd-btn rd-btn--secondary rd-superstar-ability-modal__pass" data-rd-superstar-ability-pass>Pass</button>
                            <button type="button" class="rd-btn rd-btn--primary rd-superstar-ability-modal__confirm" data-rd-superstar-ability-confirm disabled>Confirm</button>
                        </div>
                    </div>
                </div>

                <div id="rd-arsenal-reorder-modal" class="rd-arsenal-reorder-modal hidden" role="dialog" aria-modal="true">
                    <div class="rd-arsenal-reorder-modal__backdrop" aria-hidden="true"></div>
                    <div class="rd-arsenal-reorder-modal__panel">
                        <p class="rd-arsenal-reorder-modal__message" data-rd-arsenal-reorder-message></p>
                        <div class="rd-arsenal-reorder-modal__scroll" data-rd-arsenal-reorder-cards></div>
                        <div class="rd-arsenal-reorder-modal__actions">
                            <button type="button" class="rd-btn rd-btn--secondary rd-arsenal-reorder-modal__pass" data-rd-arsenal-reorder-pass>Pass</button>
                            <button type="button" class="rd-btn rd-btn--primary rd-arsenal-reorder-modal__confirm" data-rd-arsenal-reorder-confirm>Confirm</button>
                        </div>
                    </div>
                </div>

                <div id="rd-hand-reveal-modal" class="rd-hand-reveal-modal hidden" role="dialog" aria-modal="true">
                    <div class="rd-hand-reveal-modal__backdrop" aria-hidden="true"></div>
                    <div class="rd-hand-reveal-modal__panel">
                        <p class="rd-hand-reveal-modal__message" data-rd-hand-reveal-message></p>
                        <div class="rd-hand-reveal-modal__scroll" data-rd-hand-reveal-cards></div>
                        <div class="rd-hand-reveal-modal__actions">
                            <button type="button" class="rd-btn rd-btn--secondary rd-hand-reveal-modal__skip hidden" data-rd-hand-reveal-skip>Skip</button>
                            <button type="button" class="rd-btn rd-btn--primary rd-hand-reveal-modal__done" data-rd-hand-reveal-done>Done</button>
                            <button type="button" class="rd-btn rd-btn--primary rd-hand-reveal-modal__confirm hidden" data-rd-hand-reveal-confirm>Confirm</button>
                        </div>
                    </div>
                </div>

                <div id="rd-game-over" class="rd-game-over hidden">
                    <h2 id="rd-game-over-message">PINFALL!</h2>
                    <button id="rd-restart" class="rd-btn rd-btn--primary">New Match</button>
                </div>
            </div>

            <aside class="rd-sidebar">
                <div id="rd-card-preview" class="rd-card-preview">
                    <div class="rd-preview__empty">
                        <p>Hover a card to inspect it</p>
                    </div>
                    <div class="rd-preview__content hidden">
                        <div class="rd-preview__card-mount"></div>
                        <span class="rd-preview__type"></span>
                        <h2 class="rd-preview__name"></h2>
                        <div class="rd-preview__stats"></div>
                        <div class="rd-preview__section">
                            <h3>Rules Text</h3>
                            <p class="rd-preview__rules"></p>
                        </div>
                        <div class="rd-preview__section">
                            <h3>Flavor</h3>
                            <p class="rd-preview__flavor"></p>
                        </div>
                    </div>
                </div>

                <% if (devMode) { %>
                <div id="rd-dev-console" class="rd-dev-console">
                    <div class="rd-dev-console__header">Dev Console</div>
                    <div class="rd-dev-console__log" data-rd-dev-log></div>
                    <form class="rd-dev-console__form" data-rd-dev-form>
                        <input
                            type="text"
                            class="rd-dev-console__input"
                            data-rd-dev-input
                            placeholder="draw irish-whip"
                            autocomplete="off"
                            spellcheck="false"
                        />
                        <button type="submit" class="rd-btn rd-btn--secondary rd-dev-console__submit">Run</button>
                    </form>
                </div>
                <% } %>
            </aside>
        </div>
    </section>
</div>

<script src="/js/games/rawdeal/data/cards.js"></script>
<script src="/js/games/rawdeal/data/decks.js"></script>
<script src="/js/games/rawdeal/data/deckStore.js"></script>
<script src="/js/games/rawdeal/engine/constants.js"></script>
<script src="/js/games/rawdeal/engine/cardUtils.js"></script>
<script src="/js/games/rawdeal/engine/stateMachine.js"></script>
<script src="/js/games/rawdeal/engine/effectPipeline.js"></script>
<script src="/js/games/rawdeal/engine/gameEngine.js"></script>
<script src="/js/games/rawdeal/ui/cardRenderer.js"></script>
<script src="/js/games/rawdeal/ui/cardPreview.js"></script>
<script src="/js/games/rawdeal/ui/animations.js"></script>
<script src="/js/games/rawdeal/ui/choiceModal.js"></script>
<script src="/js/games/rawdeal/ui/handRevealModal.js"></script>
<script src="/js/games/rawdeal/ui/superstarAbilityModal.js"></script>
<script src="/js/games/rawdeal/ui/arsenalReorderModal.js"></script>
<script src="/js/games/rawdeal/ui/pileViewModal.js"></script>
<script src="/js/games/rawdeal/ui/board.js"></script>
<% if (devMode) { %>
<script src="/js/games/rawdeal/dev/devCommands.js"></script>
<script src="/js/games/rawdeal/dev/devConsole.js"></script>
<% } %>
<script src="/js/games/rawdeal/goldfish.js"></script>

<%- include('../../include/footer') %>