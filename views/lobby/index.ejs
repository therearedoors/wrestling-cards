<%- include('../include/header') %>
<div class="container">
    <%- include('../include/partials/responseMessage') %>
    <%- include('../include/partials/spinner') %>
    <div hidden class="lobby" id="lobby">
        <div class="my-info">
            <h4>My Info</h4>
            <ul>
                <li>
                    <label>Username:</label>
                    <span id="username">testuser</span>
                </li>
                <li>
                    <label>Rank:</label>
                    <span id="rank">beginner</span>
                </li>
                <li>
                    <label>Points:</label>
                    <span id="points">1000</span>
                </li>
            </ul>
        </div>
        <div class="rooms">
            <h1>Play</h1>
            <div class="room">
                <div class="room-info">
                    <span><strong>Raw Deal</strong></span>
                    <span>Goldfish — Rock vs Austin</span>
                </div>
                <a href="/rawdeal/goldfish">Practice</a>
            </div>
            <h2 style="margin-top: 24px; font-size: 1.2rem; opacity: 0.85;">Chess Rooms</h2>
            <div class="room">
                <div class="room-info">
                    <span><strong>Beginner</strong></span>
                    <span id="beginner-rooms">3 Rooms</span>
                </div>
                <a href="/games?rank=beginner">Play</a>
            </div>
            <div class="room">
                <div class="room-info">
                    <span><strong>Intermediate</strong></span>
                    <span id="intermediate-rooms">3 Rooms</span>
                </div>
                <a href="/games?rank=intermediate">Play</a>
            </div>
            <div class="room">
                <div class="room-info">
                    <span><strong>Advanced</strong></span>
                    <span id="advanced-rooms">3 Rooms</span>
                </div>
                <a href="/games?rank=advanced">Play</a>
            </div>
            <div class="room">
                <div class="room-info">
                    <span><strong>Expert</strong></span>
                    <span id="expert-rooms">3 Rooms</span>
                </div>
                <a href="/games?rank=expert">Play</a>
            </div>
            <p class="total" id="total-users">Total Users: 12</p>
            <p class="total" id="total-rooms">Total Rooms: 12</p>
        </div>
    </div>
</div>
<%- include('../include/partials/chat') %>
<script src="/socket.io/socket.io.js"></script>
<script src="js/index.js"></script>
<script src="js/spinner.js"></script>
<script src="js/lobby.js"></script>
<script src="js/responseMessage.js"></script>
<script src="js/chat.js"></script>
<%- include('../include/footer') %>